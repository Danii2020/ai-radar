# AI Radar — Phase 0 spike configuration.
# Copy to `.env` and adjust. Credentials are read from ~/.aws by default,
# so you usually only need this file to override the region or models.

AWS_REGION=us-east-1

# Bedrock models.
HAIKU_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0   # bulk summarization
# Chat model. Default below (Sonnet 4.5) is enabled. To use Sonnet 4.6, enable its
# model access in the Bedrock console, then uncomment the 4.6 line.
SONNET_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# SONNET_MODEL_ID=us.anthropic.claude-sonnet-4-6
EMBED_MODEL_ID=amazon.titan-embed-text-v2:0                  # RAG embeddings
EMBED_DIM=256

# Spike tuning.
SPIKE_MAX_ITEMS=8      # max items to summarize per run (cost control)
SPIKE_PER_FEED=5       # max recent entries pulled from each feed
SPIKE_TOP_K=4          # cards retrieved as grounding per chat turn

# Only needed if you are NOT using the shared ~/.aws credentials file:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
